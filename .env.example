# ── Stripe ────────────────────────────────────────────────────────────────────
# Test mode key (starts with sk_test_)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Your deployed URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://stripe-dev.vercel.app

# ── Optional: webhook secret (for verifying Stripe webhook signatures) ─────────
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
